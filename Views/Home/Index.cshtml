                        <div class="profile-info-card"><div class="profile-info-icon" style="background:rgba(15,111,255,0.1);color:var(--primary)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 17z"/></svg></div><div><p class="profile-info-label">Phone</p><p class="profile-info-value" id="profile-view-phone">—</p></div></div>
                        <div class="profile-info-card"><div class="profile-info-icon" style="background:rgba(0,201,167,0.1);color:var(--accent)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div><div><p class="profile-info-label">Email</p><p class="profile-info-value" id="profile-view-email">—</p></div></div>
                        <div class="profile-info-card"><div class="profile-info-icon" style="background:rgba(255,159,67,0.1);color:var(--warning)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div><div><p class="profile-info-label">Address</p><p class="profile-info-value" id="profile-view-address">—</p></div></div>
                        <div class="profile-info-card"><div class="profile-info-icon" style="background:rgba(99,102,241,0.1);color:#6366f1"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></div><div><p class="profile-info-label">GST Number</p><p class="profile-info-value" id="profile-view-gst">—</p></div></div>
                    </div>
                </div>
                <div id="profile-edit-mode" class="hidden">
                    <div class="profile-edit-card">
                        <form id="profile-edit-form" novalidate>
                            <div class="profile-form-grid">
                                <div class="form-group"><label>Owner / Your Name <span class="req">*</span></label><div class="input-wrapper"><svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg><input type="text" id="edit-profile-name" class="form-control" placeholder="e.g. Nevil Patel" required></div></div>
                                <div class="form-group"><label>Shop / Pharmacy Name <span class="req">*</span></label><div class="input-wrapper"><svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg><input type="text" id="edit-profile-shop" class="form-control" placeholder="e.g. Patel Medical Store" required></div></div>
                                <div class="form-group"><label>Phone Number <span class="req">*</span></label><div class="input-wrapper"><input type="tel" id="edit-profile-phone" class="form-control" placeholder="e.g. 9876543210" required></div></div>
                                <div class="form-group"><label>Shop Type <span class="req">*</span></label><div class="input-wrapper"><select id="edit-profile-type" class="form-control category-select" required><option value="">Select shop type</option><option>Pharmacy</option><option>Medical Store</option><option>Chemist</option><option>Clinic</option><option>Hospital</option><option>Other</option></select></div></div>
                                <div class="form-group profile-full-row"><label>Shop Address</label><div class="input-wrapper"><input type="text" id="edit-profile-address" class="form-control" placeholder="e.g. 12, Main Road, Surat, Gujarat"></div></div>
                                <div class="form-group profile-full-row"><label>GST Number</label><div class="input-wrapper"><input type="text" id="edit-profile-gst" class="form-control" placeholder="e.g. 24ABCDE1234F1Z5"></div></div>
                            </div>
                            <div style="display:flex;gap:0.75rem;margin-top:1.5rem;">
                                <button type="button" class="btn-modal-cancel" id="cancel-edit-profile-btn">Cancel</button>
                                <button type="submit" class="btn-login" style="flex:1;"><span>Save Changes</span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg></button>
                            </div>
                        </form>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <!-- MODALS (unchanged from original) -->
    <div class="modal-overlay hidden" id="edit-modal-overlay">
        <div class="modal-card" id="edit-modal">
            <div class="modal-header"><div class="modal-title-group"><div class="modal-icon modal-icon-edit"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></div><div><h3>Edit Medicine</h3><p>Update the details below</p></div></div><button class="modal-close" id="edit-modal-close"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>
            <form id="edit-med-form">
                <input type="hidden" id="edit-index">
                <div class="form-row"><div class="form-group"><label>Medicine Name <span class="req">*</span></label><input type="text" id="edit-name" class="form-control" required placeholder="e.g. Paracetamol 500mg"></div><div class="form-group"><label>Batch Number <span class="req">*</span></label><input type="text" id="edit-batch" class="form-control" required placeholder="e.g. B-7890"></div></div>
                <div class="form-row"><div class="form-group"><label>Remaining Quantity <span class="req">*</span></label><input type="number" id="edit-qty" class="form-control" required placeholder="e.g. 100" min="1"></div><div class="form-group"><label>Expiry Date <span class="req">*</span></label><input type="date" id="edit-expiry" class="form-control" required></div></div>
                <div class="modal-actions"><button type="button" class="btn-modal-cancel" id="edit-cancel-btn">Cancel</button><button type="submit" class="btn-modal-save"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>Save Changes</button></div>
            </form>
        </div>
    </div>

    <div class="modal-overlay hidden" id="delete-modal-overlay">
        <div class="modal-card modal-card-sm" id="delete-modal">
            <div class="modal-header"><div class="modal-title-group"><div class="modal-icon modal-icon-danger"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3,6 5,6 21,6"/><path d="M19,6v14a2,2,0,0,1-2,2H7a2,2,0,0,1-2-2V6m3,0V4a1,1,0,0,1,1-1h4a1,1,0,0,1,1,1v2"/></svg></div><div><h3>Remove Medicine</h3><p>This action cannot be undone</p></div></div><button class="modal-close" id="delete-modal-close"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>
            <div class="delete-confirm-body"><p>Are you sure you want to remove <strong id="delete-med-name"></strong> from your inventory?</p></div>
            <div class="modal-actions"><button type="button" class="btn-modal-cancel" id="delete-cancel-btn">Cancel</button><button type="button" class="btn-modal-danger" id="delete-confirm-btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3,6 5,6 21,6"/><path d="M19,6v14a2,2,0,0,1-2,2H7a2,2,0,0,1-2-2V6m3,0V4a1,1,0,0,1,1-1h4a1,1,0,0,1,1,1v2"/></svg>Yes, Remove</button></div>
        </div>
    </div>

    <div class="modal-overlay hidden" id="invoice-modal-overlay">
        <div class="modal-card" id="invoice-modal">
            <div class="invoice-modal-header">
                <h3>Inventory Invoice</h3>
                <button class="modal-close" id="invoice-modal-close"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
            </div>
            <div class="invoice-modal-body" id="invoice-print-area">
                <div id="invoice-preview"></div>
            </div>
            <div class="invoice-modal-footer">
                <button class="btn-modal-cancel" id="invoice-cancel-btn">Close</button>
                <button class="btn-modal-save" id="invoice-print-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6,9 6,2 18,2 18,9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                    Print Invoice
                </button>
            </div>
        </div>
    </div>

    <div class="toast" id="toast">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
        <span id="toast-msg"></span>
    </div>

    <script src="~/js/script.js" asp-append-version="true"></script>
</body>
</html>
